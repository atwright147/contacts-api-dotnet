{
	"prettier.enable": true,
	"eslint.enable": true,
	"editor.defaultFormatter": "esbenp.prettier-vscode",
	"editor.rulers": [80],
	"[javascript][typescript][json][jsonc]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
		"editor.formatOnSave": true
	},
	"[svelte]": {
		"editor.defaultFormatter": "svelte.svelte-vscode"
	},
	"css.lint.validProperties": ["composes"],
	"[css][scss][less]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
		"editor.formatOnSave": true
	}
}
